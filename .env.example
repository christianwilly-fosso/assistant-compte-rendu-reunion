# Toutes ces variables sont OPTIONNELLES.
# L'application fonctionne entièrement sans aucune clé.

# --- Whisper ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Limites ---
MAX_AUDIO_SIZE_MB=100

# --- Mode de résumé : auto | heuristic | gemini ---
SUMMARY_MODE=auto

# --- Groq (recommandé : free tier généreux, transcription Whisper Large V3 ultra rapide + résumé Llama 3.3 70B) ---
# https://console.groq.com/keys
# Si défini, Groq devient automatiquement le moteur de transcription ET de résumé.
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# --- Gemini (alternative au résumé, laisser vide pour rester 100% gratuit/hors-ligne) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
