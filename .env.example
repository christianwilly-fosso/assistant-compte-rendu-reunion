# Toutes ces variables sont OPTIONNELLES.
# L'application fonctionne entièrement sans aucune clé.

# --- Whisper ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Limites ---
MAX_AUDIO_SIZE_MB=100

# --- Mode de résumé : auto | heuristic | gemini ---
SUMMARY_MODE=auto

# --- Gemini (laisser vide pour rester 100% gratuit/hors-ligne) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
